<style>
  #shopify-section-{{ section.id }} {
    font-family: inherit;
  }

  #shopify-section-{{ section.id }} .chb-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 28px;
    background: #f8f8f8;
    border-bottom: 1px solid #ddd;
  }

  #shopify-section-{{ section.id }} .chb-mobile-menu {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: #000;
    line-height: 0;
  }

  #shopify-section-{{ section.id }} .chb-logo {
     font-weight: 800;
  font-size: 19px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  border-left: 3.5px solid #000;
  padding-left: 12px;
  text-decoration: none;
  color: #000;
  white-space: nowrap;
  line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .chb-announcement {
    font-size: 13.5px;
    text-align: center;
    flex: 1;
    padding: 0 28px;
    margin: 0;
    color: #111;
  }

  #shopify-section-{{ section.id }} .chb-cta-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: #f5c518;
    color: #000;
    font-weight: 700;
    font-size: 12.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 12px 24px;
    white-space: nowrap;
    overflow: hidden;
    transition: color 0.3s ease, transform 0.25s ease;
  }

  #shopify-section-{{ section.id }} .chb-cta-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #000;
    transform: translateX(-101%);
    transition: transform 0.35s ease;
    z-index: 0;
  }

  #shopify-section-{{ section.id }} .chb-cta-btn > * {
    position: relative;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .chb-cta-btn:hover {
    color: #f5c518;
  }

  #shopify-section-{{ section.id }} .chb-cta-btn:hover::before {
    transform: translateX(0);
  }

  #shopify-section-{{ section.id }} .chb-cta-btn:hover .chb-arrow {
    transform: translateX(4px);
  }

  #shopify-section-{{ section.id }} .chb-hero {
    background: #f8f8f8;
    max-width: 1400px;
    margin: 0 auto;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .chb-hero-top {
    width: 100%;
    line-height: 0;
  }

  #shopify-section-{{ section.id }} .chb-hero-top-img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .chb-hero-lower {
    display: flex;
    align-items: stretch;
  }

  #shopify-section-{{ section.id }} .chb-content {
    flex: 1 1 0;
    padding: 48px 48px 48px 48px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .chb-hero-side {
    flex: 0 0 42%;
    max-width: 42%;
    line-height: 0;
  }

  #shopify-section-{{ section.id }} .chb-hero-side-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .chb-heading {
    font-size: clamp(34px, 4.4vw, 56px);
    font-weight: 800;
    line-height: 1.05;
    margin: 0 0 18px;
    color: #000;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .chb-desc {
    font-size: 14px;
    line-height: 1.65;
    margin: 0 0 28px;
    color: #111;
  }

  #shopify-section-{{ section.id }} .chb-shop-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 16px;
    background: #000;
    color: #fff;
    font-weight: 700;
    font-size: 12.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 16px 32px;
    overflow: hidden;
    transition: color 0.3s ease;
    align-self: flex-start;
  }

  #shopify-section-{{ section.id }} .chb-shop-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #f5c518;
    transform: translateX(-101%);
    transition: transform 0.35s ease;
    z-index: 0;
  }

  #shopify-section-{{ section.id }} .chb-shop-btn > * {
    position: relative;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .chb-shop-btn:hover {
    color: #000;
  }

  #shopify-section-{{ section.id }} .chb-shop-btn:hover::before {
    transform: translateX(0);
  }

  #shopify-section-{{ section.id }} .chb-shop-btn:hover .chb-arrow {
    transform: translateX(6px);
  }

  #shopify-section-{{ section.id }} .chb-arrow {
    display: inline-block;
    transition: transform 0.3s ease;
  }

  #shopify-section-{{ section.id }} .chb-ticker {
    overflow: hidden;
    background: #fff;
    border-top: 1px solid #ddd;
    padding: 10px 0;
  }

  #shopify-section-{{ section.id }} .chb-ticker-track {
 display: flex;
  justify-content: center;
  white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .chb-ticker-track:hover {
    animation-play-state: paused;
  }

  #shopify-section-{{ section.id }} .chb-ticker-track span {
    font-size: 12px;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 0 48px;
    color: #111;
    flex-shrink: 0;
  }

  @keyframes chb-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ── Responsive  for mobile ── */
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .chb-header {
      padding: 14px 16px;
      position: relative;
      justify-content: center;
    }

    #shopify-section-{{ section.id }} .chb-mobile-menu {
      display: inline-flex;
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
    }

    #shopify-section-{{ section.id }} .chb-logo {
      border-left: none;
      padding-left: 0;
      letter-spacing: 0.18em;
      font-size: 15px;
    }

    #shopify-section-{{ section.id }} .chb-announcement,
    #shopify-section-{{ section.id }} .chb-cta-btn {
      display: none;
    }

    #shopify-section-{{ section.id }} .chb-hero-top {
      display: none;
    }

    #shopify-section-{{ section.id }} .chb-hero-lower {
      position: relative;
      display: flex;
      flex-direction: column;
    }

    #shopify-section-{{ section.id }} .chb-content {
      padding: 40px 24px 16px;
      text-align: center;
      align-items: center;
      background: #fff;
    }

    #shopify-section-{{ section.id }} .chb-heading {
      font-size: 34px;
      white-space: normal;
      text-align: center;
      margin-bottom: 14px;
    }

    #shopify-section-{{ section.id }} .chb-desc {
      text-align: center;
      max-width: 320px;
      margin: 0 auto;
    }

    #shopify-section-{{ section.id }} .chb-hero-side {
      position: static;
      flex: 0 0 auto;
      max-width: 100%;
      max-height: none;
      width: 100%;
      opacity: 1;
    }

    #shopify-section-{{ section.id }} .chb-hero-side-img {
      width: 100%;
      height: auto;
      object-fit: contain;
    }

    #shopify-section-{{ section.id }} .chb-shop-btn {
      position: absolute;
      bottom: 36px;
      left: 50%;
      transform: translateX(-50%);
      align-self: auto;
      z-index: 2;
    }
  }
</style>

<header class="chb-header">
  <button class="chb-mobile-menu" type="button" aria-label="Open menu">
    <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
      <path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>
    </svg>
  </button>

  {%- if section.settings.logo_url != blank -%}
    <a href="{{ section.settings.logo_url }}" class="chb-logo">{{ section.settings.logo_text | escape }}</a>
  {%- else -%}
    <span class="chb-logo">{{ section.settings.logo_text | escape }}</span>
  {%- endif -%}

  {%- if section.settings.announcement_text != blank -%}
    <p class="chb-announcement">{{ section.settings.announcement_text | escape }}</p>
  {%- endif -%}

  {%- if section.settings.cta_button_text != blank -%}
    <a href="{{ section.settings.cta_button_url | default: '#' }}" class="chb-cta-btn">
      <span class="chb-btn-label">{{ section.settings.cta_button_text | escape }}</span>
      <span class="chb-arrow" aria-hidden="true">&rarr;</span>
    </a>
  {%- endif -%}
</header>

<div class="chb-hero">

  <div class="chb-hero-top">
    {%- assign top_src = section.settings.top_image | image_url: width: 1400 -%}
    {%- if top_src == blank -%}
      {%- assign top_src = 'top-image.png' | asset_url -%}
    {%- endif -%}
    <img
      class="chb-hero-top-img"
      src="{{ top_src }}"
      alt=""
      aria-hidden="true"
    >
  </div>

  <div class="chb-hero-lower">
    <div class="chb-content">
      {%- if section.settings.heading != blank -%}
        <h2 class="chb-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="chb-desc">{{ section.settings.description }}</p>
      {%- endif -%}
      {%- if section.settings.shop_button_text != blank -%}
        <a href="{{ section.settings.shop_button_url | default: routes.all_products_collection_url }}" class="chb-shop-btn">
          <span class="chb-btn-label">{{ section.settings.shop_button_text | escape }}</span>
          <span class="chb-arrow" aria-hidden="true">&rarr;</span>
        </a>
      {%- endif -%}
    </div>

    {%- assign side_src = section.settings.side_image | image_url: width: 700 -%}
    {%- if side_src == blank -%}
      {%- assign side_src = 'side-image.png' | asset_url -%}
    {%- endif -%}
    <div class="chb-hero-side">
      <img
        class="chb-hero-side-img"
        src="{{ side_src }}"
        alt=""
        aria-hidden="true"
      >
    </div>
  </div>

</div>

{%- if section.settings.ticker_text != blank -%}
  <div class="chb-ticker" aria-hidden="true">
    <div class="chb-ticker-track">
     <span>{{ section.settings.ticker_text | escape }}</span>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Custom Hero Banner",
  "settings": [
    {
      "type": "header",
      "content": "Header Bar"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text",
      "default": "TISSO VISON"
    },
    {
      "type": "url",
      "id": "logo_url",
      "label": "Logo Link URL"
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement Text",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "cta_button_text",
      "label": "CTA Button Text",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "cta_button_url",
      "label": "CTA Button URL"
    },
    {
      "type": "header",
      "content": "Hero Images"
    },
    {
      "type": "paragraph",
      "content": "Top image spans the full width. Leave blank to use the default SVG illustration."
    },
    {
      "type": "image_picker",
      "id": "top_image",
      "label": "Top Image"
    },
    {
      "type": "image_picker",
      "id": "side_image",
      "label": "Side Image (right of text)"
    },
    {
      "type": "header",
      "content": "Hero Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season."
    },
    {
      "type": "text",
      "id": "shop_button_text",
      "label": "Shop Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "shop_button_url",
      "label": "Shop Button URL"
    },
    {
      "type": "header",
      "content": "Ticker"
    },
    {
      "type": "text",
      "id": "ticker_text",
      "label": "Ticker Text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    }
  ],
  "presets": [
    {
      "name": "Custom Hero Banner"
    }
  ]
}
{% endschema %}
